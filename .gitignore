# ==========================================
# ZaikOS .gitignore
# ==========================================

# ── API Keys & Secrets ──
# NEVER commit these!
.env
.env.local
.env.*.local
secrets.json

# ── Node.js / React.js ──
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log
package-lock.json  # Optional: Some prefer to commit this, but you can ignore it if you want fresh installs
soc-dashboard/node_modules/
soc-dashboard/build/
soc-dashboard/dist/
.eslintcache

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
venv/
.venv/
env/

# ── Logs & Generated Reports ──
# Ignore the logs directory and any JSON threat reports generated by the analyzer
logs/
*.log
*.json  # Note: Exclude this if you want to keep package.json tracked. Better to use specific names:
zaikos_*.json 

# ── OS & Editor Files ──
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp